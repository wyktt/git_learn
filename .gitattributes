# Auto detect text files and handle line endings
* text=auto

# Source files
*.md text
*.txt text
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary

# Git itself
.gitattributes text
.gitignore text
